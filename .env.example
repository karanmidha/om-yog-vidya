# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# RazorPay Configuration (Test Mode)
VITE_RAZORPAY_KEY_ID=your_razorpay_test_key_id
VITE_RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret

# Application Configuration
VITE_APP_NAME=OmYogVidya
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173/api

# Email Configuration (for notifications)
VITE_ADMIN_EMAIL=admin@omyogvidya.com
VITE_SUPPORT_EMAIL=support@omyogvidya.com

# Feature Flags
VITE_ENABLE_BOOKING=true
VITE_ENABLE_PAYMENT=true
VITE_ENABLE_TESTIMONIALS=true

# Debug Settings (Development Only)
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info